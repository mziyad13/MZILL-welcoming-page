<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MZILL CORP — Cybersecurity for SMBs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root {
  --bg:#080a0f;
  --surface:#0f1117;--surface2:#161820;--surface3:#1a1d28;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.12);
  --text:#eef0f7;--muted:#6b7080;--muted2:#9aa0b8;
  --accent:#3d8eff;--teal:#1fd9a0;--purple:#9d7bff;
  --amber:#f5a623;--green:#2ddb6f;--red:#ff5e6c;
  --fh:'Syne',sans-serif;--fb:'DM Sans',sans-serif;
  --r:14px;
}

html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--fb);min-height:100vh;overflow-x:hidden;}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:18px 48px;background:rgba(8,10,15,0.9);backdrop-filter:blur(20px);border-bottom:0.5px solid var(--border);}
.logo{font-family:var(--fh);font-size:18px;font-weight:800;letter-spacing:-0.01em;color:var(--text);display:flex;align-items:center;gap:8px;text-decoration:none;}
.logo-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);animation:pdot 2.5s ease infinite;}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{font-size:13px;color:var(--muted);text-decoration:none;transition:color .2s;}
.nav-links a:hover{color:var(--text);}
.nav-cta{font-family:var(--fh);font-size:13px;font-weight:600;background:var(--accent);color:#fff;padding:9px 22px;border-radius:8px;text-decoration:none;transition:all .2s;}
.nav-cta:hover{background:#5ba0ff;transform:translateY(-1px);}

/* ── BG ── */
.hero-bg{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
.hero-bg::before{content:'';position:absolute;top:20%;left:50%;transform:translate(-50%,-50%);width:800px;height:600px;background:radial-gradient(ellipse,rgba(61,142,255,0.07) 0%,transparent 65%);}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 60% at 50% 40%,black 0%,transparent 100%);}

/* ── HERO ── */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 24px 80px;position:relative;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;font-family:var(--fh);font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);background:rgba(61,142,255,.08);border:1px solid rgba(61,142,255,.2);padding:6px 16px;border-radius:100px;margin-bottom:28px;animation:fadeUp .5s ease both;}
.hero-badge-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);animation:pdot 2s ease infinite;}
h1.hero-title{font-family:var(--fh);font-size:clamp(40px,6vw,72px);font-weight:800;line-height:1.05;letter-spacing:-0.03em;margin-bottom:20px;animation:fadeUp .5s ease .1s both;}
h1.hero-title .line2{display:block;background:linear-gradient(90deg,var(--accent),var(--teal));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-sub{font-size:18px;font-weight:300;color:var(--muted);max-width:520px;line-height:1.65;margin-bottom:44px;animation:fadeUp .5s ease .2s both;}
.hero-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;animation:fadeUp .5s ease .3s both;}
.btn-primary{font-family:var(--fh);font-size:14px;font-weight:600;background:var(--accent);color:#fff;padding:13px 30px;border-radius:10px;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px;}
.btn-primary:hover{background:#5ba0ff;transform:translateY(-2px);box-shadow:0 12px 32px rgba(61,142,255,.3);}
.btn-ghost{font-family:var(--fh);font-size:14px;font-weight:500;background:transparent;color:var(--text);border:1px solid var(--border2);padding:13px 30px;border-radius:10px;text-decoration:none;transition:all .2s;}
.btn-ghost:hover{background:var(--surface);border-color:rgba(255,255,255,.2);}
.hero-stats{display:flex;gap:48px;margin-top:72px;justify-content:center;flex-wrap:wrap;animation:fadeUp .5s ease .4s both;}
.stat{text-align:center;}
.stat-num{font-family:var(--fh);font-size:28px;font-weight:800;color:var(--text);display:block;}
.stat-label{font-size:12px;color:var(--muted);margin-top:3px;}

/* ── TRUST BAND ── */
.trust-band{border-top:.5px solid var(--border);border-bottom:.5px solid var(--border);background:var(--surface);padding:40px 24px;text-align:center;}
.trust-band-inner{max-width:900px;margin:0 auto;display:flex;flex-wrap:wrap;gap:40px;justify-content:center;align-items:center;}
.trust-item{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--muted);}
.trust-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;}
.trust-icon.b{background:rgba(61,142,255,.1);}
.trust-icon.g{background:rgba(45,219,111,.1);}
.trust-icon.t{background:rgba(31,217,160,.1);}
.trust-icon.p{background:rgba(157,123,255,.1);}

/* ── SECTIONS ── */
.section{max-width:1100px;margin:0 auto;padding:100px 24px;}
.section-eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:16px;}
.eyebrow-line{width:32px;height:1px;background:var(--accent);}
.eyebrow-text{font-family:var(--fh);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);}
.section-title{font-family:var(--fh);font-size:clamp(28px,4vw,44px);font-weight:800;letter-spacing:-0.02em;line-height:1.15;margin-bottom:16px;}
.section-sub{font-size:16px;font-weight:300;color:var(--muted);max-width:480px;line-height:1.65;margin-bottom:72px;}

/* ── STEPS ── */
.steps{display:grid;grid-template-columns:1fr;gap:0;position:relative;}
.step{display:grid;grid-template-columns:80px 1fr;gap:0 28px;opacity:0;transform:translateY(24px);transition:opacity .5s ease,transform .5s ease;}
.step.visible{opacity:1;transform:translateY(0);}
.step-left{display:flex;flex-direction:column;align-items:center;}
.step-num-wrap{width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:18px;font-weight:800;flex-shrink:0;position:relative;z-index:1;border:1px solid;}
.step-line{width:1px;flex:1;min-height:40px;margin:8px 0;}
.step:last-child .step-line{display:none;}
.step-body{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:28px 32px;margin-bottom:20px;transition:border-color .25s,box-shadow .25s;cursor:default;}
.step-body:hover{border-color:var(--border2);}
.step-tag{display:inline-block;font-family:var(--fh);font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 10px;border-radius:100px;margin-bottom:12px;}
.step-title{font-family:var(--fh);font-size:20px;font-weight:700;margin-bottom:10px;letter-spacing:-0.01em;}
.step-desc{font-size:14px;font-weight:300;color:var(--muted);line-height:1.7;margin-bottom:20px;}
.step-details{display:flex;flex-wrap:wrap;gap:8px;}
.detail-pill{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:5px 12px;}
.detail-pill svg{width:13px;height:13px;flex-shrink:0;}

.s1 .step-num-wrap{background:rgba(61,142,255,.1);border-color:rgba(61,142,255,.25);color:var(--accent);}
.s1 .step-line{background:linear-gradient(to bottom,rgba(61,142,255,.4),rgba(31,217,160,.2));}
.s1 .step-tag{background:rgba(61,142,255,.1);color:#7db8ff;}
.s1 .step-body:hover{border-color:rgba(61,142,255,.25);box-shadow:0 0 32px rgba(61,142,255,.06);}
.s2 .step-num-wrap{background:rgba(31,217,160,.1);border-color:rgba(31,217,160,.25);color:var(--teal);}
.s2 .step-line{background:linear-gradient(to bottom,rgba(31,217,160,.4),rgba(157,123,255,.2));}
.s2 .step-tag{background:rgba(31,217,160,.1);color:#4de8b8;}
.s2 .step-body:hover{border-color:rgba(31,217,160,.25);box-shadow:0 0 32px rgba(31,217,160,.06);}
.s3 .step-num-wrap{background:rgba(157,123,255,.1);border-color:rgba(157,123,255,.25);color:var(--purple);}
.s3 .step-line{background:linear-gradient(to bottom,rgba(157,123,255,.4),rgba(245,166,35,.2));}
.s3 .step-tag{background:rgba(157,123,255,.1);color:#b99dff;}
.s3 .step-body:hover{border-color:rgba(157,123,255,.25);box-shadow:0 0 32px rgba(157,123,255,.06);}
.s4 .step-num-wrap{background:rgba(245,166,35,.1);border-color:rgba(245,166,35,.25);color:var(--amber);}
.s4 .step-line{background:linear-gradient(to bottom,rgba(245,166,35,.4),rgba(45,219,111,.2));}
.s4 .step-tag{background:rgba(245,166,35,.1);color:#f7bf5a;}
.s4 .step-body:hover{border-color:rgba(245,166,35,.25);box-shadow:0 0 32px rgba(245,166,35,.06);}
.s5 .step-num-wrap{background:rgba(45,219,111,.1);border-color:rgba(45,219,111,.25);color:var(--green);}
.s5 .step-tag{background:rgba(45,219,111,.1);color:#5de88a;}
.s5 .step-body:hover{border-color:rgba(45,219,111,.25);box-shadow:0 0 32px rgba(45,219,111,.06);}

/* ── AUDIT SECTION WRAPPER ── */
#audit {
  background: var(--surface);
  border-top: .5px solid var(--border);
  border-bottom: .5px solid var(--border);
  padding: 80px 24px;
}
.audit-inner {
  max-width: 760px;
  margin: 0 auto;
}
.audit-header {
  text-align: center;
  margin-bottom: 48px;
}
.audit-header .section-eyebrow { justify-content: center; }
.audit-header .section-sub { max-width: 100%; margin-bottom: 0; }

/* ── QCM STYLES ── */
.qwrap{display:none;width:100%;animation:fadeUp .4s ease both;}
.qwrap.on{display:block;}
.prog-bar-outer{display:flex;align-items:center;gap:12px;margin-bottom:22px;}
.prog-steps{display:flex;gap:4px;flex:1;}
.prog-step{flex:1;height:3px;border-radius:100px;background:var(--surface3);transition:background .4s;}
.prog-step.done{background:var(--accent);}
.prog-step.active{background:linear-gradient(90deg,var(--accent),var(--teal));}
.prog-txt{font-family:var(--fh);font-size:11px;font-weight:700;color:var(--muted);white-space:nowrap;letter-spacing:.06em;}
.qcard{background:var(--bg);border:1px solid var(--border);border-radius:18px;padding:36px 38px 32px;position:relative;overflow:hidden;}
.qcard::after{content:'';position:absolute;top:-100px;right:-100px;width:300px;height:300px;background:radial-gradient(circle,rgba(61,142,255,.04) 0%,transparent 70%);pointer-events:none;}
.q-cat{display:inline-block;font-family:var(--fh);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 11px;border-radius:100px;margin-bottom:14px;}
.c-budget{background:rgba(31,217,160,.1);color:#4de8b8;}
.c-histo{background:rgba(255,94,108,.1);color:#ff8591;}
.c-legal{background:rgba(157,123,255,.1);color:#b99dff;}
.c-equipe{background:rgba(245,166,35,.1);color:#f7bf5a;}
.c-crit{background:rgba(61,142,255,.1);color:#7db8ff;}
.c-ia{background:rgba(255,94,108,.1);color:#ff8591;}
.c-hygiene{background:rgba(245,166,35,.1);color:#f7bf5a;}
.c-supply{background:rgba(157,123,255,.1);color:#b99dff;}
.c-shadow{background:rgba(255,94,108,.1);color:#ff8591;}
.c-survie{background:rgba(45,219,111,.1);color:#5de88a;}
.q-num{font-family:var(--fh);font-size:11px;color:var(--muted);font-weight:600;margin-bottom:8px;letter-spacing:.06em;}
.q-txt{font-family:var(--fh);font-size:clamp(17px,2.8vw,22px);font-weight:700;line-height:1.28;letter-spacing:-0.01em;margin-bottom:8px;}
.q-sub{font-size:13px;color:var(--muted);font-weight:300;line-height:1.6;margin-bottom:26px;}
.q-sub strong{color:var(--amber);}
.opts{display:flex;flex-direction:column;gap:9px;}
.opt{display:flex;align-items:flex-start;gap:13px;background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:15px 18px;cursor:pointer;transition:all .17s;position:relative;overflow:hidden;}
.opt::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(61,142,255,.05),transparent);opacity:0;transition:opacity .17s;}
.opt:hover{border-color:rgba(61,142,255,.28);transform:translateX(3px);}
.opt:hover::before{opacity:1;}
.opt.sel{border-color:var(--accent);background:rgba(61,142,255,.07);}
.opt.sel::before{opacity:1;}
.opt-ltr{width:30px;height:30px;border-radius:8px;flex-shrink:0;background:var(--surface3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:11px;font-weight:700;color:var(--muted);transition:all .17s;margin-top:1px;}
.opt:hover .opt-ltr,.opt.sel .opt-ltr{background:var(--accent);border-color:var(--accent);color:#fff;}
.opt-main{font-size:14px;font-weight:400;color:var(--text);line-height:1.4;}
.opt-sub{font-size:12px;color:var(--muted);font-weight:300;margin-top:2px;}
.opt-alert{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;font-family:var(--fh);letter-spacing:.06em;padding:2px 7px;border-radius:5px;margin-top:4px;}
.alert-safe{background:rgba(31,217,160,.12);color:var(--teal);}
.alert-risk{background:rgba(255,94,108,.12);color:var(--red);}
.btn-next{margin-top:18px;width:100%;font-family:var(--fh);font-size:13px;font-weight:700;background:var(--accent);color:#fff;padding:13px 20px;border-radius:10px;border:none;cursor:pointer;transition:all .2s;display:none;align-items:center;justify-content:center;gap:8px;}
.btn-next.on{display:flex;}
.btn-next:hover{background:#5ba0ff;transform:translateY(-1px);box-shadow:0 8px 24px rgba(61,142,255,.25);}
.btn-next svg{width:15px;height:15px;}

/* ── AUDIT INTRO ── */
.audit-intro{text-align:center;animation:fadeUp .5s ease both;}
.audit-intro p{font-size:15px;font-weight:300;color:var(--muted2);line-height:1.7;margin-bottom:28px;max-width:480px;margin-left:auto;margin-right:auto;}
.audit-meta{display:flex;align-items:center;justify-content:center;gap:24px;margin-bottom:32px;flex-wrap:wrap;}
.ameta{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--muted);}
.ameta svg{width:14px;height:14px;color:var(--teal);}
.btn-start-audit{font-family:var(--fh);font-size:14px;font-weight:700;background:var(--accent);color:#fff;padding:14px 38px;border-radius:10px;border:none;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:9px;}
.btn-start-audit:hover{background:#5ba0ff;transform:translateY(-2px);box-shadow:0 14px 36px rgba(61,142,255,.3);}

/* ── RESULT ── */
.rwrap{display:none;width:100%;animation:fadeUp .5s ease both;}
.rwrap.on{display:block;}
.r-header{text-align:center;margin-bottom:28px;}
.r-icon{width:68px;height:68px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:30px;margin:0 auto 18px;}
.r-risk-label{font-size:12px;color:var(--muted);margin-bottom:4px;letter-spacing:.04em;}
.r-risk{font-family:var(--fh);font-size:42px;font-weight:800;letter-spacing:-0.02em;margin-bottom:4px;}
.r-title{font-family:var(--fh);font-size:26px;font-weight:800;letter-spacing:-0.015em;margin-bottom:8px;}
.r-sub{font-size:14px;color:var(--muted2);font-weight:300;line-height:1.65;max-width:520px;margin:0 auto;}
.pack-card{border-radius:16px;padding:28px 30px;margin-bottom:16px;border:1.5px solid;position:relative;overflow:hidden;}
.pack-card::before{content:'';position:absolute;top:-70px;right:-70px;width:240px;height:240px;border-radius:50%;opacity:.12;pointer-events:none;}
.pc-starter{background:rgba(31,217,160,.06);border-color:rgba(31,217,160,.28);}
.pc-starter::before{background:var(--teal);}
.pc-plus{background:rgba(61,142,255,.07);border-color:rgba(61,142,255,.38);}
.pc-plus::before{background:var(--accent);}
.pc-premium{background:rgba(157,123,255,.07);border-color:rgba(157,123,255,.32);}
.pc-premium::before{background:var(--purple);}
.pc-badge{font-family:var(--fh);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 11px;border-radius:100px;display:inline-block;margin-bottom:10px;}
.pc-starter .pc-badge{background:rgba(31,217,160,.14);color:var(--teal);}
.pc-plus    .pc-badge{background:rgba(61,142,255,.14);color:var(--accent);}
.pc-premium .pc-badge{background:rgba(157,123,255,.14);color:var(--purple);}
.pc-name{font-family:var(--fh);font-size:20px;font-weight:800;letter-spacing:-0.01em;margin-bottom:6px;}
.pc-why{font-size:13.5px;color:var(--muted2);font-weight:300;line-height:1.65;margin-bottom:18px;}
.pc-price-row{display:flex;align-items:baseline;gap:5px;margin-bottom:3px;}
.pc-price{font-family:var(--fh);font-size:34px;font-weight:800;}
.pc-starter .pc-price{color:var(--teal);}
.pc-plus    .pc-price{color:var(--accent);}
.pc-premium .pc-price{color:var(--purple);}
.pc-unit{font-size:14px;color:var(--muted);}
.pc-annual{font-size:12px;color:var(--muted);margin-bottom:18px;}
.pc-feats{display:flex;flex-wrap:wrap;gap:7px;}
.pc-feat{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted2);background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:7px;padding:5px 11px;}
.pc-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.pc-starter .pc-dot{background:var(--teal);}
.pc-plus    .pc-dot{background:var(--accent);}
.pc-premium .pc-dot{background:var(--purple);}
.alerts-box{background:var(--bg);border:1px solid rgba(255,94,108,.2);border-radius:14px;padding:22px 26px;margin-bottom:16px;}
.alerts-title{font-family:var(--fh);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--red);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.alert-item{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;padding-bottom:10px;border-bottom:.5px solid var(--border);}
.alert-item:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none;}
.alert-item-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.alert-item-txt{font-size:13px;color:var(--muted2);line-height:1.5;}
.alert-item-txt strong{color:var(--text);}
.score-box{background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:22px 26px;margin-bottom:16px;}
.score-title{font-family:var(--fh);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:16px;}
.srow{display:flex;align-items:center;gap:12px;margin-bottom:11px;}
.srow:last-child{margin-bottom:0;}
.slbl{font-size:13px;color:var(--muted2);width:130px;flex-shrink:0;}
.sbg{flex:1;height:6px;background:var(--surface3);border-radius:100px;overflow:hidden;}
.sfill{height:100%;border-radius:100px;width:0;transition:width 1.1s cubic-bezier(.4,0,.2,1);}
.sval{font-family:var(--fh);font-size:12px;font-weight:700;width:34px;text-align:right;}
.r-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:4px;}
.btn-action{flex:1;min-width:170px;font-family:var(--fh);font-size:13px;font-weight:700;padding:13px 18px;border-radius:10px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;text-decoration:none;}
.btn-action-primary{background:var(--accent);color:#fff;}
.btn-action-primary:hover{background:#5ba0ff;transform:translateY(-1px);box-shadow:0 8px 24px rgba(61,142,255,.25);}
.btn-action-ghost{background:transparent;color:var(--text);border:1px solid var(--border2);}
.btn-action-ghost:hover{background:var(--surface2);}
.urgency{background:rgba(255,94,108,.08);border:1px solid rgba(255,94,108,.25);border-radius:12px;padding:14px 20px;margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.urgency-icon{font-size:22px;flex-shrink:0;}
