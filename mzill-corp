  nb.innerHTML=cur<QS.length-1
    ?'Next question <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>'
    :'See my result <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
  const card=document.getElementById('qcard');
  card.classList.remove('si');void card.offsetWidth;card.classList.add('si');
  card.innerHTML=`
    <span class="q-cat ${q.catCls}">${q.cat}</span>
    <div class="q-num">Question ${q.id} of ${QS.length}</div>
    <h2 class="q-txt">${q.txt}</h2>
    <p class="q-sub">${q.sub}</p>
    <div class="opts">${q.opts.map((o,i)=>`
      <div class="opt" onclick="pickOpt(${i})">
        <div class="opt-ltr">${o.l}</div>
        <div>
          <div class="opt-main">${o.main}</div>
          <div class="opt-sub">${o.sub2}</div>
          <span class="opt-alert ${o.risk==='safe'?'alert-safe':'alert-risk'}">${o.risk==='safe'?'✓ Low risk':'⚠ High risk'}</span>
        </div>
      </div>`).join('')}
    </div>`;
}

function pickOpt(idx){
  if(sel!==null)return;
  sel=idx;
  document.querySelectorAll('.opt').forEach((el,i)=>el.classList.toggle('sel',i===idx));
  const sc=QS[cur].opts[idx].score;
  scores.s+=sc.s;scores.p+=sc.p;scores.pr+=sc.pr;
  if(QS[cur].opts[idx].risk==='risk') alerts.push({cat:QS[cur].cat,insight:QS[cur].insight,ans:QS[cur].opts[idx].main});
  document.getElementById('btnNext').classList.add('on');
}

function nextQ(){
  if(sel===null)return;
  cur++;
  if(cur>=QS.length) showResult();
  else renderQ();
}

function showResult(){
  document.getElementById('qwrap').classList.remove('on');
  const rw=document.getElementById('rwrap');
  rw.classList.add('on');
  const total=scores.s+scores.p+scores.pr||1;
  const pct={s:Math.round(scores.s/total*100),p:Math.round(scores.p/total*100),pr:Math.round(scores.pr/total*100)};
  let rec='s';
  if(scores.pr>=scores.p&&scores.pr>=scores.s)rec='pr';
  else if(scores.p>=scores.s)rec='p';
  const packs={
    s:{name:"Cyber Starter Pack",why:"Your profile shows a need for essential compliance. The Starter Pack covers the NIS 2 audit, Cyber Certificate, and basic phishing awareness — perfectly calibrated for your risk level and budget.",price:"€149",annual:"€1,788 / year",cls:"pc-starter",badge:"✓ Recommended for you",feats:["Simplified NIS 2 audit","2 phishing campaigns/year","Cyber Certificate","Monthly score report"],icon:"🛡️",ibg:"rgba(31,217,160,.12)",risk:"Low to Moderate",rc:"var(--teal)"},
    p:{name:"Cyber Plus Pack",why:"Your exposure level, team size or identified vulnerabilities justify active protection. Monthly simulations, deepfake protection and AI alerts — the Plus Pack is built for your profile.",price:"€249",annual:"€2,988 / year",cls:"pc-plus",badge:"⚡ Recommended for you",feats:["Everything in Starter +","Monthly phishing simulations","Deepfake & CEO fraud protection","AI threat alerts","Quarterly awareness session"],icon:"⚡",ibg:"rgba(61,142,255,.12)",risk:"Moderate to High",rc:"var(--accent)"},
    pr:{name:"Cyber Premium Pack",why:"Your risk level is high — several critical vulnerabilities were identified. Only the Premium Pack provides the incident response plan, priority support and dedicated expert your business needs.",price:"€499",annual:"€5,988 / year",cls:"pc-premium",badge:"👑 Recommended for you",feats:["Everything in Plus +","Priority incident support","Quarterly expert meeting","Incident response plan","Burp Suite audit included"],icon:"👑",ibg:"rgba(157,123,255,.12)",risk:"High",rc:"var(--purple)"}
  };
  const pk=packs[rec];
  rw.innerHTML=`
    <div class="r-header">
      <div class="r-icon" style="background:${pk.ibg}">${pk.icon}</div>
      <div class="r-risk-label">Your estimated risk level</div>
      <div class="r-risk" style="color:${pk.rc}">${pk.risk}</div>
      <h2 class="r-title">Our recommendation</h2>
      <p class="r-sub">Based on your 10 answers · ${alerts.length} critical vulnerabilit${alerts.length!==1?'ies':'y'} identified</p>
    </div>
    ${alerts.length>0?`<div class="urgency"><div class="urgency-icon">🚨</div><div class="urgency-txt"><strong>${alerts.length} critical vulnerabilit${alerts.length!==1?'ies':'y'} detected</strong> in your audit. See details below.</div></div>`:''}
    <div class="pack-card ${pk.cls}">
      <span class="pc-badge">${pk.badge}</span>
      <div class="pc-name">${pk.name}</div>
      <p class="pc-why">${pk.why}</p>
      <div class="pc-price-row"><span class="pc-price">${pk.price}</span><span class="pc-unit">/ month</span></div>
      <div class="pc-annual">${pk.annual} · 1-year commitment</div>
      <div class="pc-feats" style="margin-top:16px">${pk.feats.map(f=>`<div class="pc-feat"><div class="pc-dot"></div>${f}</div>`).join('')}</div>
    </div>
    ${alerts.length>0?`<div class="alerts-box"><div class="alerts-title">⚠ Vulnerabilities identified in your business</div>${alerts.map(a=>`<div class="alert-item"><div class="alert-item-icon">🔴</div><div class="alert-item-txt"><strong>${a.cat}:</strong> ${a.ans}<br><span style="font-size:12px;color:var(--muted)">${a.insight}</span></div></div>`).join('')}</div>`:''}
    <div class="score-box">
      <div class="score-title">Score breakdown by pack</div>
      <div class="srow"><span class="slbl">Starter</span><div class="sbg"><div class="sfill" id="sf-s" style="background:var(--teal)"></div></div><span class="sval" style="color:var(--teal)">${pct.s}%</span></div>
      <div class="srow"><span class="slbl">Plus</span><div class="sbg"><div class="sfill" id="sf-p" style="background:var(--accent)"></div></div><span class="sval" style="color:var(--accent)">${pct.p}%</span></div>
      <div class="srow"><span class="slbl">Premium</span><div class="sbg"><div class="sfill" id="sf-pr" style="background:var(--purple)"></div></div><span class="sval" style="color:var(--purple)">${pct.pr}%</span></div>
    </div>
    <div class="r-actions">
      <a href="#pricing" class="btn-action btn-action-primary"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>Get started with ${pk.name}</a>
      <button class="btn-action btn-action-ghost" onclick="restartAudit()">Retake the audit</button>
    </div>`;
  setTimeout(()=>{
    const sf=document.getElementById('sf-s'),pf=document.getElementById('sf-p'),prf=document.getElementById('sf-pr');
    if(sf)sf.style.width=pct.s+'%';
    if(pf)pf.style.width=pct.p+'%';
    if(prf)prf.style.width=pct.pr+'%';
  },250);
}

function startAudit(){
  document.getElementById('auditIntro').style.display='none';
  document.getElementById('qwrap').classList.add('on');
  renderQ();
}

function restartAudit(){
  cur=0;scores={s:0,p:0,pr:0};sel=null;alerts=[];
  document.getElementById('rwrap').classList.remove('on');
  document.getElementById('auditIntro').style.display='block';
  document.getElementById('qwrap').classList.remove('on');
}
</script>
</body>
</html>
